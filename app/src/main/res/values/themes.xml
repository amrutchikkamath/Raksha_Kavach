<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.RakshaKavach" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary_yellow</item>
        <item name="colorPrimaryVariant">@color/primary_yellow_dark</item>
        <item name="colorOnPrimary">@color/text_on_yellow</item>
        <item name="colorSecondary">@color/primary_yellow</item>
        <item name="colorSecondaryVariant">@color/primary_yellow_dark</item>
        <item name="colorOnSecondary">@color/text_on_yellow</item>
        <item name="android:colorBackground">@color/primary_black</item>
        <item name="colorSurface">@color/surface_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:statusBarColor">@color/primary_black</item>
        <item name="android:navigationBarColor">@color/primary_black</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

    <style name="Theme.RakshaKavach.Splash" parent="Theme.RakshaKavach">
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="YellowButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/primary_yellow</item>
        <item name="android:textColor">@color/text_on_yellow</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">16sp</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <style name="SectionTitle" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/primary_yellow</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">18sp</item>
    </style>

    <style name="CardStyle" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/surface_card</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">4dp</item>
    </style>

</resources>
