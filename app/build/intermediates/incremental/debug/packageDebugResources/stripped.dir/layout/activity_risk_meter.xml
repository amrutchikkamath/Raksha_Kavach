<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_black">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Toolbar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/surface_dark"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_back"
                android:contentDescription="Back" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Risk Meter"
                android:textColor="@color/primary_yellow"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Task Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface_dark"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp">
            <TextView
                android:id="@+id/tv_task_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Task: Not Selected"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Risk Level Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:id="@+id/ll_risk_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center"
                android:background="@color/surface_card">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RISK LEVEL"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:letterSpacing="0.15" />

                <TextView
                    android:id="@+id/tv_risk_emoji"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠️"
                    android:textSize="64sp"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/tv_risk_level"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HIGH RISK"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp" />

                <android.widget.ProgressBar
                    android:id="@+id/progress_risk"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="20dp"
                    android:layout_marginTop="16dp"
                    android:max="100"
                    android:progress="75"
                    android:progressBackgroundTint="@color/divider" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LOW"
                        android:textColor="@color/risk_low"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                    <android.widget.Space android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CRITICAL"
                        android:textColor="@color/risk_critical"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Gear Ignored Warning -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="8dp"
            android:text="INJURIES IF GEAR IS IGNORED"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:letterSpacing="0.1" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_injuries"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:nestedScrollingEnabled="false" />

        <!-- Gear Checked Status -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:layout_marginTop="20dp"
            android:text="GEAR COMPLIANCE STATUS"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:letterSpacing="0.1" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_gear_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="24dp"
            android:nestedScrollingEnabled="false" />

    </LinearLayout>
</ScrollView>
